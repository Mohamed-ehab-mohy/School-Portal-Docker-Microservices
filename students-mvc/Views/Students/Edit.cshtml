@model students_mvc.Models.Student

@{
    ViewData["Title"] = "Edit Student";
}

<div class="page-header">
    <h1>Edit Student</h1>
    <p>Update student information</p>
</div>

<div class="row justify-content-center">
    <div class="form-container">
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="FirstName" class="form-control @(!ViewData.ModelState.IsValid ? (ViewData.ModelState["FirstName"]?.Errors.Count > 0 ? "is-invalid" : "is-valid") : "")" placeholder="First Name" />
                                <label asp-for="FirstName"></label>
                                <span asp-validation-for="FirstName" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="LastName" class="form-control @(!ViewData.ModelState.IsValid ? (ViewData.ModelState["LastName"]?.Errors.Count > 0 ? "is-invalid" : "is-valid") : "")" placeholder="Last Name" />
                                <label asp-for="LastName"></label>
                                <span asp-validation-for="LastName" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control @(!ViewData.ModelState.IsValid ? (ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "is-valid") : "")" placeholder="Email Address" />
                        <label asp-for="Email"></label>
                        <span asp-validation-for="Email" class="invalid-feedback"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="DateOfBirth" type="date" class="form-control @(!ViewData.ModelState.IsValid ? (ViewData.ModelState["DateOfBirth"]?.Errors.Count > 0 ? "is-invalid" : "is-valid") : "")" placeholder="Date of Birth" />
                        <label asp-for="DateOfBirth"></label>
                        <span asp-validation-for="DateOfBirth" class="invalid-feedback"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="EnrollmentDate" type="date" class="form-control @(!ViewData.ModelState.IsValid ? (ViewData.ModelState["EnrollmentDate"]?.Errors.Count > 0 ? "is-invalid" : "is-valid") : "")" placeholder="Enrollment Date" />
                        <label asp-for="EnrollmentDate"></label>
                        <span asp-validation-for="EnrollmentDate" class="invalid-feedback"></span>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Save
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-lg"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

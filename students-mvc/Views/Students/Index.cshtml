@model IEnumerable<students_mvc.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>Students</h1>
        <p>Manage all registered students</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Create New
        </a>
    </div>
</div>

<div class="table-container">
    <table class="table table-striped mb-0">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Name)</th>
                <th>@Html.DisplayNameFor(model => model.Email)</th>
                <th>@Html.DisplayNameFor(model => model.DateOfBirth)</th>
                <th>@Html.DisplayNameFor(model => model.EnrollmentDate)</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model)
    {
            <tr>
                <td><strong>@Html.DisplayFor(modelItem => item.Name)</strong></td>
                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                <td>@item.DateOfBirth.ToString("yyyy-MM-dd")</td>
                <td>@item.EnrollmentDate.ToString("yyyy-MM-dd")</td>
                <td class="text-end text-nowrap">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Details">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>

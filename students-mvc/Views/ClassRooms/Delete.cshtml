@model students_mvc.Models.ClassRoom

@{
    ViewData["Title"] = "Delete Class";
}

<div class="page-header">
    <h1>Delete Class</h1>
    <p>Are you sure you want to delete this class?</p>
</div>

<div class="card border-danger">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9"><strong>@Model.Name</strong></dd>

            <dt class="col-sm-3">Grade</dt>
            <dd class="col-sm-9">@Model.Grade</dd>

            <dt class="col-sm-3">Room Number</dt>
            <dd class="col-sm-9">@Model.RoomNumber</dd>
        </dl>
    </div>
    <div class="card-footer">
        <form asp-action="Delete" method="post" class="d-inline">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i> Delete
            </button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Cancel
        </a>
    </div>
</div>

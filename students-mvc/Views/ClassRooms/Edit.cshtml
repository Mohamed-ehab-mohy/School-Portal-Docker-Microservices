@model students_mvc.Models.ClassRoom

@{
    ViewData["Title"] = "Edit Class";
}

<div class="page-header">
    <h1>Edit Class</h1>
    <p>Update class information</p>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="form-label">Class Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Grade" class="form-label">Grade</label>
                    <input asp-for="Grade" class="form-control" />
                    <span asp-validation-for="Grade" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="RoomNumber" class="form-label">Room Number</label>
                    <input asp-for="RoomNumber" class="form-control" />
                    <span asp-validation-for="RoomNumber" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Capacity" class="form-label">Capacity</label>
                    <input asp-for="Capacity" class="form-control" type="number" min="1" max="50" />
                    <span asp-validation-for="Capacity" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Assign Teachers</label>
                <select name="teacherIds" asp-items="@(ViewBag.TeacherList as SelectList)" class="form-select" multiple>
                </select>
                <small class="form-text text-muted">Hold Ctrl/Cmd to select multiple teachers</small>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Save
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        var selectedIds = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.SelectedTeacherIds ?? new int[0]));
        var select = document.querySelector('select[name="teacherIds"]');
        if (select && selectedIds.length > 0) {
            for (var i = 0; i < select.options.length; i++) {
                if (selectedIds.includes(parseInt(select.options[i].value))) {
                    select.options[i].selected = true;
                }
            }
        }
    </script>
}

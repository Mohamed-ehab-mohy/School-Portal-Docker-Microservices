@model students_mvc.Models.ClassRoom

@{
    ViewData["Title"] = "Class Details";
}

<div class="page-header">
    <h1>Class Details</h1>
    <p>View class information</p>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Class Information</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8"><strong>@Model.Name</strong></dd>

                    <dt class="col-sm-4">Grade</dt>
                    <dd class="col-sm-8"><span class="badge bg-primary">@Model.Grade</span></dd>

                    <dt class="col-sm-4">Room Number</dt>
                    <dd class="col-sm-8">@Model.RoomNumber</dd>

                    <dt class="col-sm-4">Capacity</dt>
                    <dd class="col-sm-8">@Model.StudentClasses.Count / @Model.Capacity</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Assigned Teachers</h5>
                @if (Model.ClassTeachers.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var ct in Model.ClassTeachers)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @ct.Teacher.FullName
                                <span class="badge bg-info">@ct.Teacher.Specialization</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">No teachers assigned</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">Enrolled Students (@Model.StudentClasses.Count)</h5>
        @if (Model.StudentClasses.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Enrolled</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sc in Model.StudentClasses)
                        {
                            <tr>
                                <td><strong>@sc.Student.FullName</strong></td>
                                <td>@sc.Student.Email</td>
                                <td>@sc.AssignedDate.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No students enrolled</p>
        }
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="bi bi-pencil"></i> Edit
            </a>
        }
    </div>
</div>

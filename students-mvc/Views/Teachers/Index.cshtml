@model IEnumerable<students_mvc.Models.Teacher>

@{
    ViewData["Title"] = "Teachers";
    var hasRecords = Model.Any();
    var isAdmin = User.IsInRole("Admin");
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>Teachers</h1>
        <p>Manage school teachers and their specializations</p>
    </div>
    @if (isAdmin)
    {
        <div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Add Teacher
            </a>
        </div>
    }
</div>

@if (hasRecords)
{
    <div class="table-container">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Specialization</th>
                    <th>Phone</th>
                    <th>Hire Date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
        @foreach (var item in Model)
        {
                <tr>
                    <td><strong>@item.FullName</strong></td>
                    <td>@item.Email</td>
                    <td><span class="badge bg-info">@item.Specialization</span></td>
                    <td>@item.Phone</td>
                    <td>@item.HireDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end text-nowrap">
                        @if (isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                        }
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Details">
                            <i class="bi bi-eye"></i>
                        </a>
                        @if (isAdmin)
                        {
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        }
                    </td>
                </tr>
        }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="card">
        <div class="empty-state">
            <div class="empty-icon">
                <i class="bi bi-person-badge"></i>
            </div>
            <h5>No teachers yet</h5>
            <p>Get started by adding your first teacher to the system.</p>
            @if (isAdmin)
            {
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Add New Teacher
                </a>
            }
        </div>
    </div>
}

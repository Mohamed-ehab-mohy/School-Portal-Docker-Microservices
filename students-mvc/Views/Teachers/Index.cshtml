@model students_mvc.Models.PaginatedList<students_mvc.Models.Teacher>

@{
    ViewData["Title"] = "Teachers";
    var hasRecords = Model.Any();
    var isAdmin = User.IsInRole("Admin");
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>Teachers</h1>
        <p>Manage school teachers and their specializations</p>
    </div>
    @if (isAdmin)
    {
        <div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Add Teacher
            </a>
        </div>
    }
</div>

<!-- Search Bar -->
<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-8">
                <label class="form-label">Search Teachers</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@Model.SearchTerm" class="form-control"
                           placeholder="Search by name, email, or specialization..." />
                </div>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> Search
                </button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg"></i> Clear
                    </a>
                }
            </div>
        </form>
    </div>
</div>

@if (hasRecords)
{
    @if (!string.IsNullOrEmpty(Model.SearchTerm))
    {
        <div class="alert alert-info">
            Found <strong>@Model.TotalCount</strong> results for "<strong>@Model.SearchTerm</strong>"
        </div>
    }

    <div class="table-container">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Specialization</th>
                    <th>Phone</th>
                    <th>Hire Date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
        @foreach (var item in Model)
        {
                <tr>
                    <td><strong>@item.FullName</strong></td>
                    <td>@item.Email</td>
                    <td><span class="badge bg-info">@item.Specialization</span></td>
                    <td>@item.Phone</td>
                    <td>@item.HireDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end text-nowrap">
                        @if (isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                        }
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Details">
                            <i class="bi bi-eye"></i>
                        </a>
                        @if (isAdmin)
                        {
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        }
                    </td>
                </tr>
        }
            </tbody>
        </table>
    </div>

    @await Component.InvokeAsync("Pagination", new { items = Model, searchTerm = Model.SearchTerm })
}
else
{
    <div class="card">
        <div class="empty-state">
            <div class="empty-icon">
                <i class="bi bi-person-badge"></i>
            </div>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <h5>No results found</h5>
                <p>No teachers match "<strong>@Model.SearchTerm</strong>". Try a different search.</p>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i> Clear Search
                </a>
            }
            else
            {
                <h5>No teachers yet</h5>
                <p>Get started by adding your first teacher to the system.</p>
                @if (isAdmin)
                {
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="bi bi-plus-lg"></i> Add New Teacher
                    </a>
                }
            }
        </div>
    </div>
}

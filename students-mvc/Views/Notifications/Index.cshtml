@model List<students_mvc.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var searchTerm = ViewBag.SearchTerm as string;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1" style="font-weight:700;color:#1a1a2e;">
            <i class="bi bi-bell-fill me-2" style="color:#4361ee;"></i>Notifications
        </h2>
        <p class="text-muted mb-0" style="font-size:0.9rem;">@totalCount notification@(totalCount != 1 ? "s" : "") total</p>
    </div>
    <div class="d-flex gap-2">
        <button onclick="markAllRead()" class="btn btn-sm" style="background:#e8f0fe;color:#4361ee;border:1px solid #c5d5f5;">
            <i class="bi bi-check2-all me-1"></i>Mark All Read
        </button>
        <button onclick="deleteAllNotifications()" class="btn btn-sm" style="background:#fff0f0;color:#e74c3c;border:1px solid #f5c6c6;">
            <i class="bi bi-trash3 me-1"></i>Delete All
        </button>
    </div>
</div>

<div class="card mb-4" style="border:1px solid #e9ecef;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.04);">
    <div class="card-body p-3">
        <form method="get" asp-action="Index" class="d-flex gap-2">
            <div class="input-group">
                <span class="input-group-text" style="background:#f8f9fa;border-right:none;border-radius:8px 0 0 8px;">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" name="search" value="@searchTerm" class="form-control" placeholder="Search notifications..."
                       style="border-left:none;border-radius:0 8px 8px 0;box-shadow:none;" />
            </div>
            <button type="submit" class="btn" style="background:#4361ee;color:#fff;border-radius:8px;padding:0 16px;">
                Search
            </button>
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <a asp-action="Index" class="btn" style="background:#f8f9fa;color:#6c757d;border:1px solid #dee2e6;border-radius:8px;">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-bell-slash" style="font-size:3rem;color:#dee2e6;"></i>
        <p class="text-muted mt-3 mb-0">No notifications found.</p>
    </div>
}
else
{
    <div class="list-group">
        @foreach (var n in Model)
        {
            var tc = n.Type switch
            {
                students_mvc.Models.NotificationType.Success => "#2ecc71",
                students_mvc.Models.NotificationType.Warning => "#f39c12",
                students_mvc.Models.NotificationType.Error => "#e74c3c",
                _ => "#4361ee"
            };
            var bg = n.IsRead ? "#ffffff" : "#f8f9ff";
            var fw = n.IsRead ? "normal" : "600";

            <div class="list-group-item d-flex align-items-start gap-3 p-3 mb-2 notif-card"
                 style="background:@bg;border:1px solid #e9ecef;border-radius:12px;font-weight:@fw;">
                <div class="d-flex align-items-center justify-content-center notif-icon"
                     style="width:44px;height:44px;min-width:44px;border-radius:12px;background:@(tc)15;">
                    <i class="bi @n.IconClass" style="font-size:1.1rem;color:@tc;"></i>
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-1" style="font-weight:600;color:#1a1a2e;">@n.Title</h6>
                            <p class="mb-1 text-muted" style="font-size:0.88rem;line-height:1.5;">@n.Message</p>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge" style="background:@(tc)20;color:@tc;font-size:0.7rem;font-weight:500;padding:4px 8px;border-radius:6px;">
                                @n.Category
                            </span>
                            @if (!n.IsRead)
                            {
                                <span style="width:8px;height:8px;border-radius:50%;background:@tc;display:inline-block;"></span>
                            }
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <small class="text-muted"><i class="bi bi-clock me-1"></i>@n.TimeAgo</small>
                        <div class="d-flex gap-2">
                            @if (!string.IsNullOrEmpty(n.Link))
                            {
                                <a href="@n.Link" onclick="markRead(@n.Id)" class="btn btn-sm"
                                   style="background:#e8f0fe;color:#4361ee;border:none;border-radius:6px;font-size:0.78rem;padding:3px 10px;">
                                    <i class="bi bi-arrow-right me-1"></i>View
                                </a>
                            }
                            @if (!n.IsRead)
                            {
                                <button onclick="markRead(@n.Id)" class="btn btn-sm"
                                        style="background:#f0f0f0;color:#666;border:none;border-radius:6px;font-size:0.78rem;padding:3px 10px;">
                                    <i class="bi bi-check me-1"></i>Read
                                </button>
                            }
                            <button onclick="deleteNotification(@n.Id)" class="btn btn-sm"
                                    style="background:#fff0f0;color:#e74c3c;border:none;border-radius:6px;font-size:0.78rem;padding:3px 10px;">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-search="@searchTerm"
                       style="border-radius:8px 0 0 8px;color:#4361ee;">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@searchTerm"
                           style="@(i == currentPage ? "background:#4361ee;border-color:#4361ee;" : "color:#4361ee;")border-radius:0;">
                            @i
                        </a>
                    </li>
                }
                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-search="@searchTerm"
                       style="border-radius:0 8px 8px 0;color:#4361ee;">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}

@section Scripts {
    <script>
        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }
        function postAction(url, onSuccess) {
            fetch(url, {
                method: 'POST',
                headers: { 'RequestVerificationToken': getAntiForgeryToken() }
            }).then(() => { if (onSuccess) onSuccess(); else location.reload(); });
        }
        function markRead(id) { postAction('/Notifications/MarkAsRead?id=' + id); }
        function markAllRead() { postAction('/Notifications/MarkAllAsRead'); }
        function deleteNotification(id) {
            if (confirm('Delete this notification?')) postAction('/Notifications/Delete?id=' + id);
        }
        function deleteAllNotifications() {
            if (confirm('Delete all your notifications?')) postAction('/Notifications/DeleteAll');
        }
    </script>
}

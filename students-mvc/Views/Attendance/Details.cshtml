@model students_mvc.Models.Attendance

@{
    ViewData["Title"] = "Attendance Details";
}

<div class="page-header">
    <h1>Attendance Details</h1>
    <p>View attendance record</p>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9"><strong>@Model.Student.FullName</strong></dd>

            <dt class="col-sm-3">Class</dt>
            <dd class="col-sm-9">@Model.ClassRoom.Name</dd>

            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.Date.ToString("MMMM dd, yyyy")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @switch (Model.Status)
                {
                    case AttendanceStatus.Present:
                        <span class="badge bg-success">Present</span>
                        break;
                    case AttendanceStatus.Absent:
                        <span class="badge bg-danger">Absent</span>
                        break;
                    case AttendanceStatus.Late:
                        <span class="badge bg-warning text-dark">Late</span>
                        break;
                    case AttendanceStatus.Excused:
                        <span class="badge bg-info">Excused</span>
                        break;
                }
            </dd>

            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@(Model.Notes ?? "No notes")</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

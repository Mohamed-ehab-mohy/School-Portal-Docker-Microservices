@model students_mvc.Models.Attendance

@{
    ViewData["Title"] = "Delete Attendance";
}

<div class="page-header">
    <h1>Delete Attendance Record</h1>
    <p>Are you sure you want to delete this attendance record?</p>
</div>

<div class="card border-danger">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9"><strong>@Model.Student.FullName</strong></dd>

            <dt class="col-sm-3">Class</dt>
            <dd class="col-sm-9">@Model.ClassRoom.Name</dd>

            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.Date.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>
    </div>
    <div class="card-footer">
        <form asp-action="Delete" method="post" class="d-inline">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i> Delete
            </button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Cancel
        </a>
    </div>
</div>

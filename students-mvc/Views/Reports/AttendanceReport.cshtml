@model students_mvc.Controllers.AttendanceReportSummary

@{
    ViewData["Title"] = "Attendance Report";
    var classes = ViewBag.Classes as List<students_mvc.Models.ClassRoom>;
    var selectedClassId = ViewBag.SelectedClassId as int?;
    var startDate = (DateTime)(ViewBag.StartDate ?? DateTime.Today.AddDays(-30));
    var endDate = (DateTime)(ViewBag.EndDate ?? DateTime.Today);
}

<div class="page-header">
    <h1>Attendance Report</h1>
    <p>Detailed attendance analytics</p>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="AttendanceReport" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Start Date</label>
                <input type="date" name="startDate" value="@startDate.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">End Date</label>
                <input type="date" name="endDate" value="@endDate.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Class</label>
                <select name="classId" class="form-select">
                    <option value="">-- All Classes --</option>
                    @if (classes is not null)
                    {
                        @foreach (var c in classes)
                        {
                            <option value="@c.Id" selected="@(selectedClassId == c.Id)">@c.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> Generate
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.TotalRecords > 0)
{
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h3 class="text-success mb-0">@Model.PresentCount</h3>
                    <p class="text-muted mb-0">Present</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h3 class="text-danger mb-0">@Model.AbsentCount</h3>
                    <p class="text-muted mb-0">Absent</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h3 class="text-warning mb-0">@Model.LateCount</h3>
                    <p class="text-muted mb-0">Late</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info">
                <div class="card-body text-center">
                    <h3 class="text-info mb-0">@Model.ExcusedCount</h3>
                    <p class="text-muted mb-0">Excused</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Daily Breakdown</h5>
        </div>
        <div class="card-body">
            <canvas id="dailyChart" height="80"></canvas>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Detailed Records</h5>
        </div>
        <div class="card-body">
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Present</th>
                        <th>Absent</th>
                        <th>Late</th>
                        <th>Excused</th>
                        <th>Rate</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var day in Model.DailyBreakdown)
                    {
                        var total = day.Present + day.Absent + day.Late + day.Excused;
                        var rate = total > 0 ? Math.Round((double)day.Present / total * 100, 1) : 0;
                        <tr>
                            <td>@day.Date.ToString("MMM dd, yyyy")</td>
                            <td><span class="badge bg-success">@day.Present</span></td>
                            <td><span class="badge bg-danger">@day.Absent</span></td>
                            <td><span class="badge bg-warning">@day.Late</span></td>
                            <td><span class="badge bg-info">@day.Excused</span></td>
                            <td>@rate%</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        var ctx = document.getElementById('dailyChart').getContext('2d');
        var chart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.DailyBreakdown.Select(d => $"'{d.Date:MMM dd}'")))],
                datasets: [
                    {
                        label: 'Present',
                        data: [@string.Join(",", Model.DailyBreakdown.Select(d => d.Present))],
                        borderColor: '#28a745',
                        backgroundColor: 'rgba(40, 167, 69, 0.1)',
                        fill: true
                    },
                    {
                        label: 'Absent',
                        data: [@string.Join(",", Model.DailyBreakdown.Select(d => d.Absent))],
                        borderColor: '#dc3545',
                        backgroundColor: 'rgba(220, 53, 69, 0.1)',
                        fill: true
                    },
                    {
                        label: 'Late',
                        data: [@string.Join(",", Model.DailyBreakdown.Select(d => d.Late))],
                        borderColor: '#ffc107',
                        backgroundColor: 'rgba(255, 193, 7, 0.1)',
                        fill: true
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'top' } },
                scales: { y: { beginAtZero: true } }
            }
        });
    </script>
}

@model students_mvc.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5 col-lg-4">
        <div class="card">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <div class="profile-icon mx-auto mb-3" style="width:64px;height:64px;font-size:1.8rem;">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <h4 class="fw-bold">Welcome Back</h4>
                    <p class="text-muted" style="font-size:0.9rem;">Sign in to your account</p>
                </div>

                <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control" placeholder="Email" autofocus />
                        <label asp-for="Email">Email</label>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Password" class="form-control" placeholder="Password" />
                        <label asp-for="Password">Password</label>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-box-arrow-in-right"></i> Sign In
                    </button>
                </form>

                <hr class="my-3" />
                <p class="text-center text-muted mb-0" style="font-size:0.85rem;">
                    Don't have an account?
                    <a asp-action="Register">Create one</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

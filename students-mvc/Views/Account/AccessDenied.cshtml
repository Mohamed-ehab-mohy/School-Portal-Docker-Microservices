@{
    ViewData["Title"] = "Access Denied";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5 text-center">
        <div class="card">
            <div class="card-body p-5">
                <div class="profile-icon mx-auto mb-3" style="width:72px;height:72px;font-size:2rem;background:linear-gradient(135deg,#ef4444,#dc2626);">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <h3 class="fw-bold text-danger">Access Denied</h3>
                <p class="text-muted">You do not have permission to access this resource.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">
                    <i class="bi bi-house"></i> Go Home
                </a>
            </div>
        </div>
    </div>
</div>

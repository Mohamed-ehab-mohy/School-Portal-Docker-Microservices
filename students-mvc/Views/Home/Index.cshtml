@{
    ViewData["Title"] = "Home";
}

<div class="hero-section">
    <div class="hero-bg-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>
    <div class="container">
        <div class="hero-content">
            <div class="hero-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <h1 class="hero-title">School Portal</h1>
            <p class="hero-subtitle">
                A modern microservices-based school management system.<br>
                Manage students, track grades, and monitor academic progress — all in one place.
            </p>
            <div class="hero-actions">
                <a asp-controller="Students" asp-action="Index" class="btn btn-hero btn-hero-primary">
                    <i class="bi bi-people-fill"></i>
                    Manage Students
                </a>
                <a href="http://localhost:5002/Grades" class="btn btn-hero btn-hero-secondary">
                    <i class="bi bi-award-fill"></i>
                    Manage Grades
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="stats-row">
        <div class="col">
            <div class="stat-card">
                <div class="stat-icon stat-icon-students">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div class="stat-info">
                    <span class="stat-number">@ViewBag.StudentCount</span>
                    <span class="stat-label">Total Students</span>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="stat-card">
                <div class="stat-icon stat-icon-enrolled">
                    <i class="bi bi-person-check-fill"></i>
                </div>
                <div class="stat-info">
                    <span class="stat-number">@ViewBag.StudentCount</span>
                    <span class="stat-label">Enrolled</span>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="stat-card">
                <div class="stat-icon stat-icon-db">
                    <i class="bi bi-database-fill"></i>
                </div>
                <div class="stat-info">
                    <span class="stat-number">
                        <span class="status-dot status-dot-green"></span>
                    </span>
                    <span class="stat-label">Database Connected</span>
                </div>
            </div>
        </div>
    </div>
</div>

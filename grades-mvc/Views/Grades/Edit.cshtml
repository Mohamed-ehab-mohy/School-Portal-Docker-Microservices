@model grades_mvc.ViewModels.GradeFormViewModel

@{
    ViewData["Title"] = "Edit Grade";
}

<div class="page-header">
    <h1>Edit Grade</h1>
    <p>Update grade information</p>
</div>

<div class="row justify-content-center">
    <div class="form-container">
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="form-floating mb-3">
                        @if (ViewBag.StudentList != null)
                        {
                            <select asp-for="StudentId" asp-items="ViewBag.StudentList" class="form-select @(!ViewData.ModelState.IsValid ? (ViewData.ModelState["StudentId"]?.Errors.Count > 0 ? "is-invalid" : "is-valid") : "")">
                                <option value="">-- Select Student --</option>
                            </select>
                        }
                        else
                        {
                            <input asp-for="StudentId" class="form-control @(!ViewData.ModelState.IsValid ? (ViewData.ModelState["StudentId"]?.Errors.Count > 0 ? "is-invalid" : "is-valid") : "")" placeholder="Student ID" />
                        }
                        <label asp-for="StudentId"></label>
                        <span asp-validation-for="StudentId" class="invalid-feedback"></span>
                        @if (ViewBag.StudentList == null)
                        {
                            <small class="text-muted">Students service unavailable. Please enter the Student ID manually.</small>
                        }
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Subject" class="form-control @(!ViewData.ModelState.IsValid ? (ViewData.ModelState["Subject"]?.Errors.Count > 0 ? "is-invalid" : "is-valid") : "")" placeholder="Subject" />
                        <label asp-for="Subject"></label>
                        <span asp-validation-for="Subject" class="invalid-feedback"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Score" class="form-control @(!ViewData.ModelState.IsValid ? (ViewData.ModelState["Score"]?.Errors.Count > 0 ? "is-invalid" : "is-valid") : "")" placeholder="Score" />
                        <label asp-for="Score"></label>
                        <span asp-validation-for="Score" class="invalid-feedback"></span>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Save
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-lg"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

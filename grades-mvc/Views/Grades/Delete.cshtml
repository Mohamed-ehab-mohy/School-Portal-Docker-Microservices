@model grades_mvc.ViewModels.GradeViewModel

@{
    ViewData["Title"] = "Delete Grade";
}

<h1>Delete Grade</h1>

@if (ViewData["WarningMessage"] is string warningMessage)
{
    <div class="alert alert-warning" role="alert">@warningMessage</div>
}

<h3>Are you sure you want to delete this grade?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Student</dt>
        <dd class="col-sm-10">@Model.StudentName</dd>
        <dt class="col-sm-2">Student ID</dt>
        <dd class="col-sm-10">@Model.StudentId</dd>
        <dt class="col-sm-2">Subject</dt>
        <dd class="col-sm-10">@Model.Subject</dd>
        <dt class="col-sm-2">Score</dt>
        <dd class="col-sm-10">@Model.Score</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>

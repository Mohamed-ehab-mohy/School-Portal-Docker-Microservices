@model grades_mvc.ViewModels.GradeViewModel

@{
    ViewData["Title"] = "Delete Grade";
}

<div class="page-header">
    <h1>Delete Grade</h1>
    <p>Are you sure you want to delete this grade? This action cannot be undone.</p>
</div>

@if (ViewData["WarningMessage"] is string warningMessage)
{
    <div class="alert alert-warning" role="alert">@warningMessage</div>
}

<div class="row justify-content-center">
    <div class="form-container">
        <div class="card border-danger">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 3rem;"></i>
                    <h5 class="mt-2 text-danger">Delete Confirmation</h5>
                </div>

                <table class="table table-borderless mb-4">
                    <tr>
                        <td class="text-muted fw-semibold">Student</td>
                        <td>@Model.StudentName</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Student ID</td>
                        <td>@Model.StudentId</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Subject</td>
                        <td>@Model.Subject</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Score</td>
                        <td>@Model.Score</td>
                    </tr>
                </table>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="submit" class="btn btn-danger btn-lg px-4 btn-delete-pulse">
                            <i class="bi bi-trash3-fill"></i> Delete
                        </button>
                        <a asp-action="Index" class="btn btn-secondary btn-lg px-4">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@model IEnumerable<grades_mvc.ViewModels.GradeViewModel>

@{
    ViewData["Title"] = "Grades";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>Grades</h1>
        <p>Manage student grades and scores</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Create New
        </a>
    </div>
</div>

@if (ViewData["WarningMessage"] is string warningMessage)
{
    <div class="alert alert-warning d-flex align-items-center gap-2" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <span>@warningMessage</span>
    </div>
}

<div class="table-container">
    <table class="table table-striped mb-0">
        <thead>
            <tr>
                <th>Student</th>
                <th>Student ID</th>
                <th>Subject</th>
                <th>Score</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model)
    {
            <tr>
                <td>
                    @if (item.IsStudentServiceUnavailable)
                    {
                        <span class="badge bg-secondary">ID: @item.StudentId</span>
                    }
                    else
                    {
                        <strong>@item.StudentName</strong>
                    }
                </td>
                <td>@item.StudentId</td>
                <td>@item.Subject</td>
                <td><strong>@item.Score</strong></td>
                <td class="text-end text-nowrap">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Details">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>

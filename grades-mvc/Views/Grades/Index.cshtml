@model IEnumerable<grades_mvc.ViewModels.GradeViewModel>

@{
    ViewData["Title"] = "Grades";
    var hasRecords = Model.Any();
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>Grades</h1>
        <p>Manage student grades and scores</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Create New
        </a>
    </div>
</div>

@if (hasRecords)
{
    <div class="table-container">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Course</th>
                    <th>Score</th>
                    <th>Date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
        @foreach (var item in Model)
        {
                <tr>
                    <td><strong>@item.StudentName</strong></td>
                    <td>@item.CourseName</td>
                    <td><strong>@item.Score</strong></td>
                    <td>@item.GradeDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end text-nowrap">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Details">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
        }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="card">
        <div class="empty-state">
            <div class="empty-icon">
                <i class="bi bi-journal-text"></i>
            </div>
            <h5>No grades yet</h5>
            <p>Start by adding the first grade entry for a student.</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Add New Grade
            </a>
        </div>
    </div>
}

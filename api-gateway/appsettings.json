{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "students-api": {
        "ClusterId": "students-cluster",
        "Match": {
          "Path": "/api/students/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/students/{**catch-all}" }
        ]
      },
      "students-pages": {
        "ClusterId": "students-cluster",
        "Match": {
          "Path": "/students/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/students/{**catch-all}" }
        ]
      },
      "students-teachers-api": {
        "ClusterId": "students-cluster",
        "Match": {
          "Path": "/api/teachers/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/teachers/{**catch-all}" }
        ]
      },
      "teachers-pages": {
        "ClusterId": "students-cluster",
        "Match": {
          "Path": "/Teachers/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/Teachers/{**catch-all}" }
        ]
      },
      "classrooms-pages": {
        "ClusterId": "students-cluster",
        "Match": {
          "Path": "/ClassRooms/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/ClassRooms/{**catch-all}" }
        ]
      },
      "attendance-pages": {
        "ClusterId": "students-cluster",
        "Match": {
          "Path": "/Attendance/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/Attendance/{**catch-all}" }
        ]
      },
      "students-home": {
        "ClusterId": "students-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        },
        "Conditions": [
          {
            "Methods": ["GET"],
            "Headers": [
              { "Header": "X-Forwarded-Service", "Values": ["students"] }
            ]
          }
        ],
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "grades-api": {
        "ClusterId": "grades-cluster",
        "Match": {
          "Path": "/grades-api/grades/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/grades/{**catch-all}" }
        ]
      },
      "grades-pages": {
        "ClusterId": "grades-cluster",
        "Match": {
          "Path": "/grades/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/grades/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "students-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://students-mvc:8080/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:10",
            "Path": "/health"
          }
        },
        "LoadBalancingPolicy": "RoundRobin"
      },
      "grades-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://grades-mvc:8080/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:10",
            "Path": "/health"
          }
        },
        "LoadBalancingPolicy": "RoundRobin"
      }
    }
  }
}
